# Public URL of your Spring API (same paths as locally: /api/..., /uploads/... if used).
# Leave unset to use relative "/api" (works with Vite dev proxy only; set this on Vercel).
# Example: https://your-backend.railway.app
VITE_API_URL=

# Stripe publishable key (pk_test_... or pk_live_...) for card payment at checkout.
# Leave empty to hide "Proceed to payment" and only show "Place order" (orders stay PENDING).
VITE_STRIPE_PUBLISHABLE_KEY=
